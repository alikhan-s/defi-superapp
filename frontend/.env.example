# DeFi Super-App frontend — environment template.
# Copy to `.env` and fill in. Only VITE_*-prefixed vars are exposed to the client.

# The Graph endpoint for the Phase 10 subgraph (Studio query URL or self-hosted).
# Example (Subgraph Studio): https://api.studio.thegraph.com/query/<id>/defi-superapp/<version>
VITE_SUBGRAPH_URL=https://api.studio.thegraph.com/query/00000/defi-superapp/v0.0.1

# WalletConnect Cloud project id (https://cloud.walletconnect.com). Required for
# WalletConnect-based connectors in RainbowKit; injected wallets work without it.
VITE_WALLETCONNECT_PROJECT_ID=58667b2315d6ab59325f8abcd13bff33

# Dedicated Arbitrum Sepolia RPC (e.g. Alchemy/Infura). Strongly recommended —
# the default public RPC is rate-limited/stale and makes contract simulations
# fail intermittently. If unset, falls back to the public endpoint.
VITE_ARBITRUM_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
